<!doctype html>
<html lang="{{ page.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% if page.description %}
    <meta name="description" content="{{ page.description }}">
    {% endif %}
    <title>{{ page.title }}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f8ff;
        --surface: #ffffff;
        --surface-soft: #f8faff;
        --text: #1e293b;
        --muted: #64748b;
        --brand: #4f46e5;
        --brand-soft: #e0e7ff;
        --ok: #0f766e;
        --warn: #b45309;
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        color: var(--text);
        background:
          radial-gradient(900px 360px at 85% -10%, rgba(79, 70, 229, .13), transparent),
          radial-gradient(700px 280px at 8% -15%, rgba(34, 197, 94, .08), transparent),
          var(--bg);
      }

      .wrap { max-width: 1080px; margin: 0 auto; padding: 1.6rem 1rem 2.8rem; }
      .hero {
        border: 1px solid #dbe1ff;
        background: linear-gradient(150deg, #ffffff, #f5f7ff);
        border-radius: 18px;
        padding: 1.1rem 1.2rem;
        box-shadow: 0 22px 40px rgba(79, 70, 229, 0.08);
      }
      h1 { margin: 0; font-size: clamp(1.4rem, 1.05rem + 1.9vw, 2.2rem); }
      .sub { margin: .45rem 0 0; color: var(--muted); }
      .meta { display: flex; flex-wrap: wrap; gap: .45rem; margin-top: .8rem; }
      .badge {
        border: 1px solid #d6dbff;
        border-radius: 999px;
        padding: .16rem .56rem;
        font-size: .78rem;
        color: #3730a3;
        background: #eff2ff;
      }

      .layout { margin-top: .95rem; display: grid; grid-template-columns: 1fr; gap: .9rem; }
      .card {
        background: var(--surface);
        border: 1px solid #e6e9f5;
        border-radius: 14px;
        padding: .88rem .95rem;
      }
      .section-title { margin: 0 0 .72rem; font-size: 1rem; }
      .items { display: grid; gap: .72rem; }
      .item {
        background: var(--surface-soft);
        border: 1px solid #e7eaf8;
        border-radius: 12px;
        padding: .72rem;
      }
      .kind { display: inline-block; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); }
      .title { margin: .35rem 0 .45rem; font-size: 1.02rem; }
      .content { margin: 0; line-height: 1.6; color: #334155; white-space: pre-wrap; }
      .chips { margin-top: .55rem; display: flex; flex-wrap: wrap; gap: .36rem; }
      .chip {
        border-radius: 999px;
        padding: .14rem .5rem;
        font-size: .72rem;
        border: 1px solid #d6dcf7;
        background: #ffffff;
      }
      .chip.ok { border-color: #9cd5ca; color: #0f766e; }
      .chip.warn { border-color: #f4c992; color: #b45309; }
      details.item > summary { cursor: pointer; list-style: none; }
      details.item > summary::-webkit-details-marker { display: none; }
      .lazy-mark { color: var(--muted); font-size: .8rem; margin-left: .42rem; }

      .controls {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: .6rem;
        margin-bottom: .7rem;
      }
      label { display: block; font-size: .76rem; color: var(--muted); margin-bottom: .22rem; }
      input, textarea {
        width: 100%;
        border: 1px solid #d7ddf7;
        border-radius: 10px;
        background: #fff;
        color: var(--text);
        padding: .5rem .56rem;
        font: inherit;
      }
      textarea { min-height: 84px; resize: vertical; }
      .svc-list { display: grid; gap: .65rem; }
      .svc-head { display: flex; justify-content: space-between; gap: .5rem; flex-wrap: wrap; margin-bottom: .5rem; }
      .svc-name { margin: 0; font-size: .95rem; }
      .actions { margin-top: .5rem; display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; }
      button {
        border: 1px solid #cdd4ff;
        border-radius: 10px;
        padding: .42rem .66rem;
        background: linear-gradient(160deg, #f3f5ff, #fff);
        color: #312e81;
        font-weight: 600;
        cursor: pointer;
      }
      button:hover { border-color: #b6c0ff; }
      .output {
        margin-top: .45rem;
        background: #f7f9ff;
        border: 1px solid #d9e0ff;
        border-radius: 10px;
        padding: .55rem;
        min-height: 76px;
        max-height: 260px;
        overflow: auto;
        white-space: pre-wrap;
        color: #1d4ed8;
      }

      footer { margin-top: 1.4rem; color: var(--muted); font-size: .82rem; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="hero">
        <h1>{{ page.title }}</h1>
        {% if page.description %}<p class="sub">{{ page.description }}</p>{% endif %}
        <div class="meta">
          <span class="badge">sections {{ stats.sections_total }}</span>
          <span class="badge">services {{ stats.services_total }}</span>
          <span class="badge">eager {{ stats.eager_count }}</span>
          <span class="badge">lazy {{ stats.lazy_count }}</span>
          <span class="badge">hidden {{ stats.never_count }}</span>
          {% if request.fragment %}<span class="badge">fragment {{ request.fragment }}</span>{% endif %}
        </div>
      </header>

      <main class="layout">
        <section class="card">
          <h2 class="section-title">Document Items</h2>
          <div class="items">
          {% for item in items %}
            {% if item.collapsed %}
            <details class="item {{ item.class_attr }}" id="{{ item.id }}">
              <summary>
                <span class="kind">{{ item.kind }}</span>
                <h3 class="title">{{ item.title }}<span class="lazy-mark">lazy</span></h3>
              </summary>
              <p class="content">{{ item.content }}</p>
              {% if item.kind == "service" %}
              <div class="chips">
                {% if item.effects %}<span class="chip ok">effects {{ item.effects }}</span>{% endif %}
                {% if item.consent_mode %}<span class="chip warn">consent {{ item.consent_mode }}</span>{% endif %}
                {% if item.source_ref %}<span class="chip">endpoint /{{ item.source_ref }}</span>{% endif %}
              </div>
              {% endif %}
            </details>
            {% else %}
            <article class="item {{ item.class_attr }}" id="{{ item.id }}">
              <span class="kind">{{ item.kind }}</span>
              <h3 class="title">{{ item.title }}</h3>
              <p class="content">{{ item.content }}</p>
              {% if item.kind == "service" %}
              <div class="chips">
                {% if item.effects %}<span class="chip ok">effects {{ item.effects }}</span>{% endif %}
                {% if item.consent_mode %}<span class="chip warn">consent {{ item.consent_mode }}</span>{% endif %}
                {% if item.source_ref %}<span class="chip">endpoint /{{ item.source_ref }}</span>{% endif %}
              </div>
              {% endif %}
            </article>
            {% endif %}
          {% endfor %}
          </div>
        </section>

        <section class="card">
          <h2 class="section-title">Service Console</h2>
          <div class="controls">
            <div>
              <label for="admin-token">admin bearer token (for capability/interactive)</label>
              <input id="admin-token" value="change-this-admin-token">
            </div>
            <div>
              <label for="agent-id">agent id (optional, for allowAgents policy)</label>
              <input id="agent-id" value="trusted-agent">
            </div>
          </div>

          <div class="svc-list">
          {% for service in services %}
            <article class="item" id="console-{{ loop.index0 }}">
              <div class="svc-head">
                <h3 class="svc-name">{{ service.id }}</h3>
                <div class="chips">
                  <span class="chip">/{{ service.source_ref }}</span>
                  <span class="chip ok">effects {{ service.effects }}</span>
                  <span class="chip warn">consent {{ service.consent.mode }}</span>
                </div>
              </div>
              <label for="payload-{{ loop.index0 }}">JSON payload</label>
              <textarea id="payload-{{ loop.index0 }}">{"a": 7, "b": 13}</textarea>
              <div class="actions">
                <button type="button"
                  data-service-id="{{ service.id }}"
                  data-source-ref="{{ service.source_ref }}"
                  data-consent-mode="{{ service.consent.mode }}"
                  data-index="{{ loop.index0 }}"
                  onclick="invokeService(this)">
                  Run Service
                </button>
              </div>
              <pre class="output" id="output-{{ loop.index0 }}">等待调用...</pre>
            </article>
          {% endfor %}
          </div>
        </section>
      </main>

      <footer>
        template {{ runtime.template_source }}
      </footer>
    </div>

    <script>
      async function postJson(url, body, extraHeaders = {}) {
        const response = await fetch(url, {
          method: "POST",
          headers: Object.assign({ "content-type": "application/json" }, extraHeaders),
          body: JSON.stringify(body),
        });
        const data = await response.json().catch(() => ({ message: "non-json response" }));
        if (!response.ok) {
          throw { status: response.status, data };
        }
        return data;
      }

      function parsePayload(index) {
        const raw = document.getElementById(`payload-${index}`).value;
        return JSON.parse(raw);
      }

      function setOutput(index, label, data) {
        const node = document.getElementById(`output-${index}`);
        node.textContent = `${label}\n${JSON.stringify(data, null, 2)}`;
      }

      async function invokeService(button) {
        const serviceId = button.dataset.serviceId;
        const sourceRef = button.dataset.sourceRef;
        const consentMode = button.dataset.consentMode;
        const index = button.dataset.index;
        const adminToken = document.getElementById("admin-token").value.trim();
        const agentId = document.getElementById("agent-id").value.trim();

        let payload;
        try {
          payload = parsePayload(index);
        } catch (err) {
          setOutput(index, "Invalid payload", { message: String(err) });
          return;
        }

        const invokeHeaders = {};
        if (agentId) {
          invokeHeaders["x-web4-agent-id"] = agentId;
        }

        try {
          if (consentMode === "capability") {
            const issued = await postJson(
              "/consent/issue",
              { service_id: serviceId, ttl_seconds: 600 },
              { authorization: `Bearer ${adminToken}` }
            );
            invokeHeaders.authorization = `W4-Capability ${issued.token}`;
            const result = await postJson(`/${sourceRef.replace(/^\/+/, "")}`, payload, invokeHeaders);
            setOutput(index, "Capability success", { token: issued, result });
            return;
          }

          if (consentMode === "interactive") {
            const challenge = await postJson(
              "/consent/challenge",
              { service_id: serviceId, ttl_seconds: 600 },
              { authorization: `Bearer ${adminToken}` }
            );
            await postJson(
              `/consent/challenge/${challenge.challenge_id}/approve`,
              {},
              { authorization: `Bearer ${adminToken}` }
            );
            invokeHeaders["x-web4-challenge"] = challenge.challenge_id;
            const result = await postJson(`/${sourceRef.replace(/^\/+/, "")}`, payload, invokeHeaders);
            setOutput(index, "Interactive success", { challenge, result });
            return;
          }

          const result = await postJson(`/${sourceRef.replace(/^\/+/, "")}`, payload, invokeHeaders);
          setOutput(index, "Open success", result);
        } catch (err) {
          setOutput(index, "Call failed", err);
        }
      }
    </script>
  </body>
</html>
